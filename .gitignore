# Local / OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Secrets
.env
.env.*
*.local.json
*.local.toml

# Node (if scripts use it later)
node_modules/

# Python (if scripts use it later)
__pycache__/
*.pyc

# AI - this repository intentionally dogfoods its own Claude + Codex install.
# Track the project-local Claude/Codex config, route files, selected skills,
# .mcp reference files, .kit-version, and .kit-manifest.
#
# Keep local/runtime files out of Git.
/.claude/settings.local.json
/.claude/session-log/
/.claude/worktrees/
CLAUDE.local.md

# Local release-readiness signal written by the /cut-release command.
.verify-state

# Local install/update audit record written by install.* / update.* (#313).
.ai-agent-kit/install-audit.ndjson

# Local runtime lock written by the scheduled-task / loop feature.
/.claude/scheduled_tasks.lock

# Runtime cache written by CLI tools (e.g. gh, agy).
/cache/
