{
  "model": {
    "name": "gemini-3-flash",
    "maxSessionTurns": 100,
    "compressionThreshold": 0.6
  },
  "context": {
    "fileName": ["AGENTS.md", "AGY.md", "CONTEXT.md"]
  },
  "general": {
    "checkpointing": {
      "enabled": true
    }
  },
  "tools": {
    "sandbox": false,
    "useRipgrep": true,
    "core": [],
    "allowed": [],
    "exclude": []
  },
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \".agy/hooks/run-hook.ps1\" pre-bash-guard.sh",
            "name": "pre-bash-guard",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
