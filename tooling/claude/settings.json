{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet format:*)",
      "Bash(dotnet run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(ng:*)",
      "Bash(vue-tsc:*)",
      "Bash(vite:*)",
      "Bash(vitest:*)",
      "Bash(npx vitest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "WebFetch(domain:docs.microsoft.com)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:vuejs.org)",
      "WebFetch(domain:angular.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:packaging.python.org)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:doc.rust-lang.org)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:docs.flutter.dev)",
      "WebFetch(domain:api.flutter.dev)",
      "WebFetch(domain:expo.dev)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:kubernetes.io)",
      "WebFetch(domain:developer.hashicorp.com)",
      "WebFetch(domain:graphql.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:kotlinlang.org)",
      "WebFetch(domain:docs.spring.io)",
      "WebFetch(domain:docs.gradle.org)",
      "WebFetch(domain:maven.apache.org)",
      "WebFetch(domain:junit.org)",
      "WebFetch(domain:svelte.dev)",
      "WebFetch(domain:kit.svelte.dev)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout -- :*)",
      "Bash(git checkout .:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -df:*)",
      "Bash(git clean --force:*)",
      "Bash(git switch --discard-changes:*)",
      "Bash(git switch --force:*)",
      "Bash(git switch -f:*)",
      "Bash(git switch -C:*)",
      "Bash(git switch --force-create:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-bash-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/format-on-save.sh\"",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notify-done.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session-summary.sh\"",
            "async": false
          }
        ]
      }
    ]
  }
}
