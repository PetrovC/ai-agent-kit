{
  "model": {
    "name": "gemini-3-pro-preview"
  },

  "context": {
    "fileName": ["AGENTS.md", "GEMINI.md", "CONTEXT.md"]
  },

  "general": {
    "checkpointing": {
      "enabled": true
    }
  },

  "tools": {
    "sandbox": false,
    "core": [],
    "allowed": [],
    "exclude": []
  },

  "mcpServers": {
  },

  "hooksConfig": {
    "enabled": true
  },

  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/pre-bash-guard.sh",
            "name": "pre-bash-guard",
            "timeout": 5000,
            "description": "Denylist guard: blocks force-push, branch -D, ref deletion, reset --hard, switch --discard-changes, clean -f, rm -rf on dangerous targets, and unapproved SQL DROP."
          }
        ]
      }
    ]
  },

  "advanced": {
    "excludedEnvVars": [
      "*_SECRET",
      "*_TOKEN",
      "*_KEY",
      "*_PASSWORD",
      "OPENAI_*",
      "ANTHROPIC_*",
      "AWS_*",
      "GCP_*",
      "GOOGLE_*",
      "*_URL",
      "*_URI",
      "*_DSN"
    ]
  }
}
